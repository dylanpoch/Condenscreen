n_cells    = n(),
median_CNS = round(median(CNS), 4),
.groups    = "drop"
) %>%
left_join(
stat.test %>% select(group2, p.adj, p.adj.signif) %>%
rename(Names = group2),
by = "Names"
)
# --- Prepare bin counts df ---
bin_counts_df <- stack_df %>%
select(Names, CNS_bin, n, pct) %>%
rename(Condition = Names, Bin = CNS_bin, N_Cells = n, Pct_Cells = pct)
# --- Build workbook ---
fileX <- paste0(pathName, "CNS_export.xlsx")
wb    <- createWorkbook()
addWorksheet(wb, "CNS")
addWorksheet(wb, "MLF2-GFP")
addWorksheet(wb, "tdTomato")
# CNS sheet — two tables: summary and bin counts
writeData(wb, "CNS", results_df,    startCol = 1, startRow = 1,  colNames = TRUE)
writeData(wb, "CNS", bin_counts_df, startCol = 1, startRow = nrow(results_df) + 3, colNames = TRUE)
freezePane(wb, "CNS", firstActiveRow = 2)
addFilter(wb, "CNS", rows = 1, cols = 1:ncol(results_df))
# MLF2 sheet
writeData(wb, "MLF2-GFP", mlf2_df, startCol = 1, startRow = 1, colNames = TRUE)
freezePane(wb, "MLF2-GFP", firstActiveRow = 2)
addFilter(wb, "MLF2-GFP", rows = 1, cols = 1:ncol(mlf2_df))
# tdTomato sheet
writeData(wb, "tdTomato", tdt_df, startCol = 1, startRow = 1, colNames = TRUE)
freezePane(wb, "tdTomato", firstActiveRow = 2)
addFilter(wb, "tdTomato", rows = 1, cols = 1:ncol(tdt_df))
fileX <- paste0(pathName, "CNS_ZincExport.xlsx"
saveWorkbook(wb, fileX, overwrite = TRUE)
fileX <- paste0(pathName, "CNS_ZincExport.xlsx")
saveWorkbook(wb, fileX, overwrite = TRUE)
sub_df3 %>%
wilcox_test(CNS ~ Names, ref.group = "PZ, 2 µM") %>%
adjust_pvalue(method = "bonferroni") %>%
add_significance("p.adj") %>%
filter(group2 != "PZ, 2 µM")
# --- Wilcoxon on raw CNS vs Untreated ---
stat.test <- sub_df3 %>%
wilcox_test(CNS ~ Names, ref.group = "PZ, 2 µM") %>%
adjust_pvalue(method = "bonferroni") %>%
add_significance("p.adj") %>%
filter(group2 != "PZ, 2 µM")
stat.test$x_pos <- as.numeric(factor(stat.test$group2, levels = level_order))
# --- 100% stacked summary ---
stack_df <- sub_df3 %>%
group_by(Names, CNS_bin) %>%
summarise(n = n(), .groups = "drop") %>%
group_by(Names) %>%
mutate(pct = n / sum(n) * 100)
# --- Median labels ---
median_df <- sub_df3 %>%
group_by(Names) %>%
summarise(med = round(median(CNS), 3), .groups = "drop")
# --- Plot ---
sub_plot_stacked <- ggplot(stack_df, aes(x = Names, y = pct, fill = CNS_bin)) +
geom_bar(stat = "identity", width = 0.7, color = "black", linewidth = 0.3) +
# stat significance nearest to bars (y=102), then p-value below it (y=108)
geom_text(data = stat.test,
aes(x = x_pos, y = 105, label = p.adj.signif),
inherit.aes = FALSE,
size = 7, fontface = "bold") +
scale_fill_manual(
values = c(
"≤ 2x DMSO median" = "#F4622A",   # orange
"2-5x DMSO median"  = "#C2185B",   # red-pink
"> 5x DMSO median"  = "#6A0572"    # dark purple
)
) +
scale_y_continuous(limits = c(0, 120), breaks = seq(0, 100, 25),
labels = paste0(seq(0, 100, 25), "%")) +
labs(y = "% of Cells", fill = "CNS Score") +
theme_classic() +
theme(
axis.title.y      = element_text(size = 22, face = "bold"),
axis.title.x      = element_blank(),
axis.text.x       = element_text(size = 16, angle = 55, hjust = 1),
axis.text.y       = element_text(size = 16),
legend.text       = element_text(size = 16),
legend.title      = element_text(size = 18, face = "bold"),
legend.position   = "right",
legend.background = element_blank()
)
ggsave(paste0(pathName, "CNS_Stacked_Bar.PDF"), sub_plot_stacked, width = 8, height = 8)
# --- Export results to xlsx  ---
library(openxlsx)
# --- Prepare Summary results df ---
results_df <- sub_df3 %>%
group_by(Names) %>%
summarise(
n_cells    = n(),
median_CNS = round(median(CNS), 4),
.groups    = "drop"
) %>%
left_join(
stat.test %>% select(group2, p.adj, p.adj.signif) %>%
rename(Names = group2),
by = "Names"
)
# --- Prepare bin counts df ---
bin_counts_df <- stack_df %>%
select(Names, CNS_bin, n, pct) %>%
rename(Condition = Names, Bin = CNS_bin, N_Cells = n, Pct_Cells = pct)
# --- Build workbook ---
fileX <- paste0(pathName, "CNS_export.xlsx")
wb    <- createWorkbook()
addWorksheet(wb, "CNS")
addWorksheet(wb, "MLF2-GFP")
addWorksheet(wb, "tdTomato")
# CNS sheet — two tables: summary and bin counts
writeData(wb, "CNS", results_df,    startCol = 1, startRow = 1,  colNames = TRUE)
writeData(wb, "CNS", bin_counts_df, startCol = 1, startRow = nrow(results_df) + 3, colNames = TRUE)
freezePane(wb, "CNS", firstActiveRow = 2)
addFilter(wb, "CNS", rows = 1, cols = 1:ncol(results_df))
# MLF2 sheet
writeData(wb, "MLF2-GFP", mlf2_df, startCol = 1, startRow = 1, colNames = TRUE)
freezePane(wb, "MLF2-GFP", firstActiveRow = 2)
addFilter(wb, "MLF2-GFP", rows = 1, cols = 1:ncol(mlf2_df))
# tdTomato sheet
writeData(wb, "tdTomato", tdt_df, startCol = 1, startRow = 1, colNames = TRUE)
freezePane(wb, "tdTomato", firstActiveRow = 2)
addFilter(wb, "tdTomato", rows = 1, cols = 1:ncol(tdt_df))
fileX <- paste0(pathName, "CNS_ZincExport.xlsx")
saveWorkbook(wb, fileX, overwrite = TRUE)
